generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ConnectivityTest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  status    String   @default("success")
  latency   Int?
  message   String?

  @@map("connectivity_tests")
}
